<?xml version="1.0" encoding="utf-8"?>
<!--
    Fondo de pantalla tipo degradado para la pantalla de Login.
    Simula un fondo profesional con tonos azules oscuros.
    Reemplazar por un BitmapDrawable si se quiere usar una imagen real:
    <bitmap xmlns:android="http://schemas.android.com/apk/res/android"
        android:src="@drawable/imagen_fondo"
        android:scaleType="centerCrop" />
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Capa 1: Degradado de fondo principal (simula fondo imagen) -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#0D1B5E"
                android:centerColor="#1A3A8F"
                android:endColor="#1A6DC0"
                android:angle="135"
                android:type="linear" />
        </shape>
    </item>

    <!-- Capa 2: Patrón de puntos suaves para textura -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#11FFFFFF" />
        </shape>
    </item>

</layer-list>
