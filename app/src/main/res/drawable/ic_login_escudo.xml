        android:fillColor="#1565C0"
        android:pathData="M50,24 L67,32 L67,52 Q67,64 50,73 Q33,64 33,52 L33,32 Z" />

    <!-- Candado cuerpo -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M43,50 L43,62 L57,62 L57,50 Q57,44 50,44 Q43,44 43,50 Z" />

    <!-- Candado arco superior -->
