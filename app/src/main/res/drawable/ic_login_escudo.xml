        android:fillColor="#FFFFFF"
        android:fillAlpha="0"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:pathData="M44,50 L44,45 Q44,39 50,39 Q56,39 56,45 L56,50" />

    <!-- Punto de cerradura -->
    <path
        android:fillColor="#1565C0"
        android:pathData="M50,53 m-3,0 a3,3 0 1,0 6,0 a3,3 0 1,0 -6,0" />

    <!-- Línea cerradura -->
    <path
        android:fillColor="#1565C0"
        android:pathData="M49,56 L49,60 L51,60 L51,56 Z" />

</vector>
