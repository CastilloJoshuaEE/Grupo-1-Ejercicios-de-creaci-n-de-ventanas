<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/fondo_degradado">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp">

        <!-- ===== CABECERA ===== -->
        <LinearLayout
            android:id="@+id/layoutCabecera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/colorCabecera"
            android:orientation="vertical"
            android:paddingTop="40dp"
            android:paddingBottom="16dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/nombre_institucion"
                android:textColor="@color/blanco"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/nombre_carrera"
                android:textColor="@color/blancoSemiTransparente"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="2dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/datos_grupo"
                android:textColor="@color/blancoSemiTransparente"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="2dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/nombre_docente"
                android:textColor="@color/blancoSemiTransparente"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <!-- ===== TARJETA DEL FORMULARIO ===== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="12dp"
            app:cardBackgroundColor="@color/blanco">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="28dp"
                android:paddingBottom="24dp">

                <!-- Título formulario -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Crear Cuenta"
                    android:textColor="@color/colorPrimario"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Complete el formulario de registro"
                    android:textColor="@color/grisTexto"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:layout_marginTop="4dp" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:layout_gravity="center"
                    android:background="@color/colorAcento"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="20dp" />

                <!-- ===== CÉDULA ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Cédula *"
                    android:textColor="@color/grisOscuro"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxStrokeColor="@color/colorPrimario"
                    app:hintTextColor="@color/colorPrimario">

                    <EditText
                        android:id="@+id/campoCedula"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Ingrese su cédula"
                        android:inputType="number"
                        android:maxLines="1"
                        android:maxLength="13"
                        android:textColor="@color/negroTexto"
                        android:textSize="15sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ===== NOMBRES ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nombres *"
                    android:textColor="@color/grisOscuro"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxStrokeColor="@color/colorPrimario"
                    app:hintTextColor="@color/colorPrimario">

                    <EditText
                        android:id="@+id/campoNombres"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Ingrese sus nombres"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:textColor="@color/negroTexto"
                        android:textSize="15sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ===== APELLIDOS ===== -->

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"
                    android:text="Apellidos *"
                    android:textColor="@color/grisOscuro"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxStrokeColor="@color/colorPrimario"
                    app:hintTextColor="@color/colorPrimario">

                    <EditText
                        android:id="@+id/campoApellidos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Ingrese sus apellidos"
                        android:inputType="textPersonName"
                        android:maxLines="1"
                        android:textColor="@color/negroTexto"
                        android:textSize="15sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ===== EDAD ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Edad *"
                    android:textColor="@color/grisOscuro"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:boxStrokeColor="@color/colorPrimario"
                    app:hintTextColor="@color/colorPrimario">

                    <EditText
                        android:id="@+id/campoEdad"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Ingrese su edad"
                        android:inputType="number"
                        android:maxLines="1"
                        android:maxLength="3"
                        android:textColor="@color/negroTexto"
                        android:textSize="15sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <!-- ===== NACIONALIDAD (SPINNER) ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nacionalidad *"
                    android:textColor="@color/grisOscuro"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/spinnerNacionalidad"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/spinner_background"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="15sp" />

                <!-- ===== GÉNERO (SPINNER) ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Género *"
                    android:textColor="@color/grisOscuro"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <Spinner
                    android:id="@+id/spinnerGenero"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/spinner_background"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:textSize="15sp" />

                <!-- ===== ESTADO CIVIL (RADIO BUTTONS) ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Estado Civil *"
                    android:textColor="@color/grisOscuro"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/radioGroupEstadoCivil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <RadioButton
                        android:id="@+id/radioSoltero"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Soltero/a"
                        android:textColor="@color/negroTexto"
                        android:textSize="15sp"
                        android:buttonTint="@color/colorPrimario" />

                    <RadioButton
                        android:id="@+id/radioCasado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Casado/a"
                        android:textColor="@color/negroTexto"
                        android:textSize="15sp"
                        android:buttonTint="@color/colorPrimario" />

                    <RadioButton
                        android:id="@+id/radioDivorciado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Divorciado/a"
                        android:textColor="@color/negroTexto"
                        android:textSize="15sp"
                        android:buttonTint="@color/colorPrimario" />

                    <RadioButton
                        android:id="@+id/radioViudo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Viudo/a"
                        android:textColor="@color/negroTexto"
                        android:textSize="15sp"
                        android:buttonTint="@color/colorPrimario" />

                    <RadioButton
                        android:id="@+id/radioUnionLibre"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unión Libre"
                        android:textColor="@color/negroTexto"
                        android:textSize="15sp"
                        android:buttonTint="@color/colorPrimario" />

                </RadioGroup>

                <!-- ===== FECHA DE NACIMIENTO (DatePicker Fragment) ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Fecha de Nacimiento *"
                    android:textColor="@color/grisOscuro"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <TextView
                    android:id="@+id/txtFechaNacimiento"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Toque para seleccionar fecha"
                    android:textColor="@color/grisTexto"
                    android:textSize="15sp"
                    android:gravity="center_vertical"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/spinner_background"
                    android:clickable="true"
                    android:focusable="true" />

                <!-- ===== NIVEL DE INGLÉS (RATINGBAR) ===== -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nivel de Inglés"
                    android:textColor="@color/grisOscuro"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="6dp" />

                <RatingBar
                    android:id="@+id/ratingBarIngles"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:numStars="5"
                    android:stepSize="1"
                    android:rating="0"
                    android:progressTint="@color/colorAcento"
                    android:layout_marginBottom="24dp" />

                <!-- ===== SEPARADOR ===== -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/grisTexto"
                    android:alpha="0.3"
                    android:layout_marginBottom="20dp"/>

                <!-- ===== BOTONES ===== -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Botón Registrar -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/botonRegistrar"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="4dp"
                        android:text="Registrar"
                        android:textSize="13sp"
                        android:textColor="@color/blanco"
                        app:backgroundTint="@color/colorPrimario"
                        app:cornerRadius="10dp" />

                    <!-- Botón Borrar -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/botonBorrar"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:layout_marginEnd="4dp"
                        android:text="Borrar"
                        android:textSize="13sp"
                        android:textColor="@color/colorAcento"
                        app:strokeColor="@color/colorAcento"
                        app:cornerRadius="10dp" />

                    <!-- Botón Cancelar -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/botonCancelar"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:layout_marginStart="4dp"
                        android:text="Cancelar"
                        android:textSize="13sp"
                        android:textColor="@color/grisOscuro"
                        app:strokeColor="@color/grisOscuro"
                        app:cornerRadius="10dp" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/botonVerRegistros"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Ver Registros"
                        android:layout_marginTop="16dp"
                        style="@style/Widget.Material3.Button.OutlinedButton" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Pie de página -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="@string/pie_pagina"
            android:textColor="@color/blancoSemiTransparente"
            android:textSize="11sp"
            android:layout_marginTop="20dp" />

    </LinearLayout>

</ScrollView>
