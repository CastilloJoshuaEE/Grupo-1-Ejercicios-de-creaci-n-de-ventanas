<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Tema base de la aplicación -->
    <style name="Theme.LoginApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Colores principales -->
        <item name="colorPrimary">@color/colorPrimario</item>
        <item name="colorPrimaryVariant">@color/colorPrimarioVariante</item>
        <item name="colorOnPrimary">@color/blanco</item>
        <item name="colorSecondary">@color/colorAcento</item>
        <item name="colorOnSecondary">@color/blanco</item>

        <!-- Fondo de la app -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/colorFondoInicio</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <!-- Tipografía -->
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <!-- Tema para la pantalla de carga (Splash) -->
    <style name="Theme.LoginApp.SplashScreen" parent="Theme.LoginApp">
        <item name="android:windowBackground">@drawable/fondo_degradado</item>
    </style>

</resources>
